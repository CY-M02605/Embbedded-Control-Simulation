{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "cmake: configure gear_display_facade",
      "type": "shell",
      "command": "cmake",
      "args": [
        "-S",
        "${workspaceFolder}/gear_display_facade",
        "-B",
        "${workspaceFolder}/gear_display_facade/build"
      ],
      "problemMatcher": []
    },
    {
      "label": "cmake: build gear_display_facade Debug",
      "type": "shell",
      "command": "cmake",
      "args": [
        "--build",
        "${workspaceFolder}/gear_display_facade/build",
        "--config",
        "Debug"
      ],
      "dependsOn": "cmake: configure gear_display_facade",
      "problemMatcher": [
        "$msCompile"
      ],
      "group": "build"
    }
  ]
